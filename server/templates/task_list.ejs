<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Microsoft YaHei', Arial, sans-serif; line-height: 1.8; color: #333; max-width: 700px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #409eff 0%, #67c23a 100%); color: white; padding: 30px; text-align: center; border-radius: 12px 12px 0 0; }
        .header h1 { margin: 0 0 8px 0; font-size: 26px; }
        .header p { margin: 0; opacity: 0.9; font-size: 14px; }
        .content { background: #f9fafb; padding: 25px; border-radius: 0 0 12px 12px; }
        .task-item { background: white; border-radius: 10px; padding: 18px 20px; margin-bottom: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); border-left: 4px solid #409eff; }
        .task-item:last-child { margin-bottom: 0; }
        .task-item.urgent { border-left-color: #f56c6c; }
        .task-item.secondary { border-left-color: #909399; }
        .task-item.important { border-left-color: #e6a23c; }
        .task-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .task-title { font-size: 16px; font-weight: 600; color: #303133; margin: 0; }
        .task-badge { padding: 3px 10px; border-radius: 4px; font-size: 12px; font-weight: 500; }
        .badge-紧急 { background: #fef0f0; color: #f56c6c; }
        .badge-重要 { background: #fdf6ec; color: #e6a23c; }
        .badge-次要 { background: #f4f4f5; color: #909399; }
        .task-meta { display: flex; gap: 20px; font-size: 13px; color: #606266; margin-bottom: 8px; }
        .task-meta span { display: flex; align-items: center; }
        .task-meta .label { color: #909399; margin-right: 5px; }
        .task-target { background: #f5f7fa; padding: 10px 12px; border-radius: 6px; font-size: 13px; color: #606266; margin: 0; white-space: pre-wrap; word-break: break-all; }
        .task-tags { margin-top: 10px; }
        .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; background: #ecf5ff; color: #409eff; margin-right: 5px; }
        .status-badge { padding: 2px 8px; border-radius: 10px; font-size: 11px; margin-left: 10px; }
        .status-0 { background: #f4f4f5; color: #909399; }
        .status-1 { background: #ecf5ff; color: #409eff; }
        .status-2 { background: #fdf6ec; color: #e6a23c; }
        .status-3 { background: #f0f9ff; color: #10b981; }
        .summary { background: white; border-radius: 10px; padding: 15px 20px; margin-bottom: 20px; display: flex; justify-content: space-around; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        .summary-item .num { font-size: 22px; font-weight: bold; color: #409eff; }
        .summary-item .text { font-size: 12px; color: #909399; margin-top: 3px; }
        .footer { text-align: center; color: #909399; font-size: 12px; margin-top: 25px; padding-top: 20px; border-top: 1px solid #ebeef5; }
        .no-data { text-align: center; padding: 40px; color: #c0c4cc; font-size: 14px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>📋 任务清单</h1>
        <p><%= reportDate %></p>
    </div>
    <div class="content">
        <% if (summary) { %>
        <div class="summary">
            <div class="summary-item">
                <div class="num"><%= summary.total %></div>
                <div class="text">总任务</div>
            </div>
            <div class="summary-item">
                <div class="num" style="color: #f56c6c;"><%= summary.overdue %></div>
                <div class="text">已超期</div>
            </div>
            <div class="summary-item">
                <div class="num" style="color: #e6a23c;"><%= summary.urgent %></div>
                <div class="text">紧急</div>
            </div>
            <div class="summary-item">
                <div class="num" style="color: #10b981;"><%= summary.completed %></div>
                <div class="text">已完成</div>
            </div>
        </div>
        <% } %>

        <% if (tasks && tasks.length) { %>
            <% tasks.forEach(function(task) { %>
            <div class="task-item <%= task.importance === '紧急' ? 'urgent' : task.importance === '重要' ? 'important' : 'secondary' %>">
                <div class="task-header">
                    <h3 class="task-title"><%= task.title %></h3>
                    <span class="task-badge badge-<%= task.importance %>"><%= task.importance %></span>
                </div>
                <div class="task-meta">
                    <span><span class="label">编号:</span><%= task.id %></span>
                    <span><span class="label">状态:</span><span class="status-badge status-<%= task.status %>"><%= task.statusName %></span></span>
                    <span><span class="label">创建:</span><%= task.createTime %></span>
                    <span><span class="label">截止:</span><%= task.closeTime %></span>
                </div>
                <% if (task.target) { %>
                <div class="task-target"><%= task.target %></div>
                <% } %>
                <% if (task.tags && task.tags.length) { %>
                <div class="task-tags">
                    <% task.tags.forEach(function(tag) { %>
                    <span class="tag">标签<%= tag %></span>
                    <% }); %>
                </div>
                <% } %>
            </div>
            <% }); %>
        <% } else { %>
        <div class="no-data">暂无任务清单</div>
        <% } %>
    </div>
    <div class="footer">
        <p>此邮件由 Homebition 系统自动发送</p>
    </div>
</body>
</html>
