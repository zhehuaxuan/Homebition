<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 700px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 25px; text-align: center; border-radius: 12px 12px 0 0; }
        .header h1 { margin: 0 0 10px 0; font-size: 24px; }
        .header p { margin: 0; opacity: 0.9; font-size: 14px; }
        .content { background: #f8f9fa; padding: 20px; border-radius: 0 0 12px 12px; }
        .stats { display: flex; justify-content: space-around; background: white; padding: 15px; border-radius: 8px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .stat-item { text-align: center; }
        .stat-value { font-size: 24px; font-weight: bold; color: #667eea; }
        .stat-label { font-size: 12px; color: #666; margin-top: 5px; }
        .task-table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .task-table th { background: #667eea; color: white; padding: 12px 10px; text-align: left; font-size: 13px; font-weight: 500; }
        .task-table td { padding: 12px 10px; border-bottom: 1px solid #eee; font-size: 13px; vertical-align: middle; }
        .task-table tr:last-child td { border-bottom: none; }
        .task-table tr:hover { background: #f8f9fa; }
        .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin: 2px; background: #e0e7ff; color: #4338ca; }
        .status { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; }
        .status-进行中 { background: #dbeafe; color: #1d4ed8; }
        .status-待启动 { background: #f3f4f6; color: #6b7280; }
        .status-已完成 { background: #d1fae5; color: #059669; }
        .status-挂起中 { background: #fef3c7; color: #d97706; }
        .status-紧急 { background: #fee2e2; color: #dc2626; }
        .status-至关重要 { background: #fee2e2; color: #dc2626; }
        .importance { font-weight: bold; }
        .importance-紧急 { color: #dc2626; }
        .importance-至关重要 { color: #dc2626; }
        .importance-重要 { color: #d97706; }
        .remain-days { font-weight: 500; }
        .remain-days-negative { color: #dc2626; }
        .footer { text-align: center; color: #888; font-size: 12px; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee; }
        .text-ellipsis { max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .no-data { text-align: center; padding: 40px; color: #999; }
    </style>
</head>
<body>
    <div class="header">
        <h1>📋 任务周报</h1>
        <p><%= reportDate %></p>
    </div>
    <div class="content">
        <% if (summary) { %>
        <div class="stats">
            <div class="stat-item">
                <div class="stat-value"><%= summary.total %></div>
                <div class="stat-label">总任务</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= summary.doing %></div>
                <div class="stat-label">进行中</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= summary.completed %></div>
                <div class="stat-label">已完成</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" style="color: #dc2626;"><%= summary.overdue %></div>
                <div class="stat-label">已超期</div>
            </div>
        </div>
        <% } %>

        <% if (tasks && tasks.length) { %>
        <table class="task-table">
            <thead>
                <tr>
                    <th style="width: 15%;">任务名称</th>
                    <th style="width: 10%;">重要性</th>
                    <th style="width: 8%;">状态</th>
                    <th style="width: 8%;">剩余天数</th>
                    <th style="width: 12%;">开始日期</th>
                    <th style="width: 12%;">闭环日期</th>
                    <th style="width: 20%;">标签</th>
                    <th style="width: 15%;">目标</th>
                </tr>
            </thead>
            <tbody>
                <% tasks.forEach(function(task) { %>
                <tr>
                    <td><strong><%= task.title %></strong></td>
                    <td>
                        <span class="importance importance-<%= task.importance %>"><%= task.importance %></span>
                    </td>
                    <td>
                        <span class="status status-<%= task.status %>"><%= task.status %></span>
                    </td>
                    <td>
                        <span class="remain-days <%= task.remainDays < 0 ? 'remain-days-negative' : '' %>">
                            <%= task.remainDays < 0 ? '超期' + Math.abs(task.remainDays) + '天' : task.remainDays + '天' %>
                        </span>
                    </td>
                    <td><%= task.create_time %></td>
                    <td><%= task.close_time %></td>
                    <td>
                        <% if (task.tags && task.tags.length) { %>
                            <% task.tags.forEach(function(tag) { %>
                                <span class="tag"><%= tag %></span>
                            <% }); %>
                        <% } else { %>
                            <span style="color: #ccc;">-</span>
                        <% } %>
                    </td>
                    <td class="text-ellipsis" title="<%= task.target %>">
                        <%= task.target ? task.target.substring(0, 20) + (task.target.length > 20 ? '...' : '') : '-' %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
        <% } else { %>
        <div class="no-data">暂无任务数据</div>
        <% } %>
    </div>
    <div class="footer">
        <p>此邮件由 Homebition 系统自动发送</p>
        <p>Generated by Homebition</p>
    </div>
</body>
</html>
