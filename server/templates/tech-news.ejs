<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 12px 12px 0 0; }
    .header h1 { margin: 0; font-size: 22px; }
    .header .date { margin-top: 8px; font-size: 14px; opacity: 0.9; }
    .content { background: white; padding: 20px; border-radius: 0 0 12px 12px; }

    .section-title { font-size: 16px; font-weight: 600; color: #333; margin: 20px 0 12px; padding-bottom: 6px; border-bottom: 2px solid #667eea; }
    .section-title:first-of-type { margin-top: 0; }

    /* Highlight */
    .highlight { margin-bottom: 20px; }
    .highlight-card { background: linear-gradient(135deg, #fff8e1, #fff3cd); border: 1px solid #ffe082; border-radius: 10px; padding: 16px; margin-bottom: 10px; }
    .highlight-card:last-child { margin-bottom: 0; }
    .highlight-label { font-size: 11px; color: #f57f17; font-weight: 600; margin-bottom: 4px; }
    .highlight-title { font-size: 15px; font-weight: 600; }
    .highlight-title a { color: #1a73e8; text-decoration: none; }
    .highlight-title a:hover { text-decoration: underline; }
    .highlight-summary { font-size: 13px; color: #555; margin-top: 4px; line-height: 1.5; }

    /* Section */
    .section { margin-bottom: 20px; }
    .item { margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid #f0f0f0; }
    .item:last-child { border-bottom: none; }
    .item-title { font-size: 14px; font-weight: 600; }
    .item-title a { color: #1a73e8; text-decoration: none; }
    .item-title a:hover { text-decoration: underline; }
    .item-summary { font-size: 13px; color: #666; margin-top: 4px; line-height: 1.5; }
    .item-summary .up { color: #c62828; font-weight: 600; }
    .item-summary .down { color: #2e7d32; font-weight: 600; }
    .item-meta { margin-top: 4px; }
    .source-tag { display: inline-block; font-size: 11px; color: #667eea; background: #f0f0ff; padding: 2px 8px; border-radius: 10px; }
    .date-tag { display: inline-block; font-size: 11px; color: #888; background: #f5f5f5; padding: 2px 8px; border-radius: 10px; margin-right: 4px; }
    .market-price { font-size: 16px; font-weight: 600; }
    .market-price.up { color: #c62828; }
    .market-price.down { color: #2e7d32; }

    /* Stock section special */
    .section.stock { border-left: 4px solid #f44336; padding-left: 12px; }
    .section.stock .section-title { border-bottom-color: #f44336; }
    .section.stock .item { background: #fff8f8; padding: 10px; border-radius: 6px; border-bottom: none; margin-bottom: 8px; }
    .section.stock .item-title a { color: #c62828; }
    .sub-section { margin-bottom: 10px; }
    .sub-title { font-size: 13px; font-weight: 600; color: #c62828; margin-bottom: 6px; padding: 4px 8px; background: #fff0f0; border-radius: 4px; display: inline-block; }

    .footer { text-align: center; padding: 16px; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= data.subject || 'AI 技术前沿早报' %></h1>
      <div class="date"><%= data.date %></div>
    </div>
    <div class="content">
      <!-- Highlight -->
      <% if (data.highlight && data.highlight.length > 0) { %>
        <div class="section-title">🔥 今日头条</div>
        <div class="highlight">
          <% data.highlight.forEach(function(item) { %>
            <div class="highlight-card">
              <div class="highlight-label">📌 头条推荐</div>
              <div class="highlight-title"><a href="<%= item.url %>" target="_blank"><%= item.title %></a></div>
              <div class="highlight-summary"><%= item.summary %></div>
              <% if (item.source) { %>
                <div class="item-meta"><span class="source-tag"><%= item.source %></span></div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>

      <!-- Sections -->
      <% if (data.sections && data.sections.length > 0) { %>
        <% data.sections.forEach(function(section) { %>
          <div class="section <%= section.name === '市场脉动' ? 'stock' : '' %>">
            <div class="section-title"><%= section.icon || '📄' %> <%= section.name %></div>
            <% if (section.subsections && section.subsections.length > 0) { %>
              <!-- 市场脉动子版块 -->
              <% section.subsections.forEach(function(sub) { %>
                <% if (sub.items && sub.items.length > 0) { %>
                  <div class="sub-section">
                    <div class="sub-title">▸ <%= sub.name %></div>
                    <% sub.items.forEach(function(item) { %>
                      <div class="item">
                        <div class="item-title">
                          <% if (item.price) { %>
                            <span class="market-price <%= item.change >= 0 ? 'up' : 'down' %>"><%= item.price.toFixed(2) %></span>
                          <% } %>
                          <a href="<%= item.url %>" target="_blank"><%= item.title %></a>
                        </div>
                        <div class="item-summary">
                          <% if (item.change !== undefined) { %>
                            <span class="<%= item.change >= 0 ? 'up' : 'down' %>">
                              <%= (item.change >= 0 ? '+' : '') + item.change.toFixed(2) %>（<%= (item.changePct >= 0 ? '+' : '') + item.changePct.toFixed(2) %>%）
                            </span>
                            · <%= item.summary.split('·').slice(2).join('·') %>
                          <% } else { %>
                            <%= item.summary %>
                          <% } %>
                        </div>
                        <% if (item.date || item.source) { %>
                          <div class="item-meta">
                            <% if (item.date) { %><span class="date-tag"><%= item.date %></span><% } %>
                            <% if (item.source) { %><span class="source-tag"><%= item.source %></span><% } %>
                          </div>
                        <% } %>
                      </div>
                    <% }); %>
                  </div>
                <% } %>
              <% }); %>
            <% } else if (section.items && section.items.length > 0) { %>
              <% section.items.forEach(function(item) { %>
                <div class="item">
                  <div class="item-title"><a href="<%= item.url %>" target="_blank"><%= item.title %></a></div>
                  <div class="item-summary"><%= item.summary %></div>
                  <% if (item.source) { %>
                    <div class="item-meta"><span class="source-tag"><%= item.source %></span></div>
                  <% } %>
                </div>
              <% }); %>
            <% } %>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color: #999; text-align: center;">暂无资讯内容</p>
      <% } %>
    </div>
    <div class="footer">
      由 Homebition AI 生成 · <%= data.date %>
    </div>
  </div>
</body>
</html>
